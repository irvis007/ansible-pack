---
# Production Environment Inventory
# Use this for actual workstations and production servers

all:
  vars:
    ansible_python_interpreter: /usr/bin/python3
    environment_name: production
    ansible_ssh_private_key_file: "{{ lookup('env', 'HOME') }}/.ssh/ansible_prod_key"

  children:
    # Production Workstations
    workstations:
      hosts:
        # Example: Your main laptop
        # my-laptop:
        #   ansible_connection: local

        # Example: Team member workstation
        # dev-workstation-01:
        #   ansible_host: 10.0.1.50
        #   ansible_user: ansible

      vars:
        # Development tools
        install_docker: true
        install_astronvim: true
        install_zsh: true

        # Security settings for workstations
        apply_hardening: false  # Workstations don't need full hardening
        ufw_enabled: false      # Usually behind corporate firewall

    # Production Servers
    servers:
      children:
        # Web servers group
        web_servers:
          hosts:
            # web-prod-01:
            #   ansible_host: 10.0.2.10
            #   ansible_user: ansible

          vars:
            # Web server specific rules
            ufw_rules:
              - rule: allow
                port: "{{ ssh_custom_port }}"
                proto: tcp
                comment: "SSH"
              - rule: allow
                port: "80"
                proto: tcp
                comment: "HTTP"
              - rule: allow
                port: "443"
                proto: tcp
                comment: "HTTPS"

        # Application servers group
        app_servers:
          hosts:
            # app-prod-01:
            #   ansible_host: 10.0.2.20
            #   ansible_user: ansible

          vars:
            # App server specific configuration
            ufw_rules:
              - rule: allow
                port: "{{ ssh_custom_port }}"
                proto: tcp
                comment: "SSH"

      # All servers inherit these vars
      vars:
        # Strict security for production servers
        apply_hardening: true
        ufw_enabled: true
        fail2ban_enabled: true
        ssh_password_authentication: no
        sudo_passwordless_allowed: false

        # Automatic updates enabled
        unattended_upgrades_enabled: true
